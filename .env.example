# FPL Team Picker - Environment Variables
# Copy this file to .env and adjust values as needed.

# Backend Settings
FPL_DEBUG=false
FPL_HOST=0.0.0.0
FPL_PORT=8000

# FPL API
FPL_FPL_BASE_URL=https://fantasy.premierleague.com/api
FPL_FPL_RATE_LIMIT=1.0

# Cache
FPL_CACHE_DIR=.cache
FPL_CACHE_BOOTSTRAP_TTL=21600
FPL_CACHE_ELEMENT_TTL=14400
FPL_CACHE_FIXTURES_TTL=86400
FPL_CACHE_LIVE_TTL=60
FPL_CACHE_PREDICTIONS_TTL=3600

# CORS
FPL_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=/api
